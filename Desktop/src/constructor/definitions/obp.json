                    "id": "position",
                    "label": "Положение",
                    "type": "buttonSelect",
                    "options": [
                      { "value": "шейке", "label": "шейка" },
                      { "value": "теле", "label": "тело" },
                      { "value": "дне", "label": "дно" }
