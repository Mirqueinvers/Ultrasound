{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "./dist-api",
    "rootDir": "./src",
    "declaration": false,
    "sourceMap": true
  },
  "include": ["src/db.ts", "src/api.ts", "src/api/**/*.ts"],
  "exclude": ["node_modules"]
}
